# === LLM 配置 ===
# OpenAI API Key（支持 OpenAI 兼容 API）
OPENAI_API_KEY=your-api-key-here
# API Base URL（OpenAI 兼容 API 地址）
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认模型
DEFAULT_MODEL=gpt-4o-mini

# === 数据存储配置 ===
# 数据目录路径（默认使用用户目录，可配置为独立目录）
# Windows 示例：C:\eval-agent\data
# Linux/Mac 示例：/var/lib/eval-agent/data
# EVAL_DATA_DIR=

# === 重试配置 ===
# 业务逻辑最大重试次数
EVAL_MAX_RETRIES=3
# LLM 调用最大重试次数
EVAL_LLM_MAX_RETRIES=5
# LLM 重试基础延迟（秒），实际延迟 = base_delay * attempt
EVAL_LLM_RETRY_DELAY=1.0

# === 并发配置 ===
# 后台任务线程数
EVAL_MAX_WORKERS=1
# Review 并发数
EVAL_LLM_WORKERS=4
# LLM 并发调用数
EVAL_LLM_CONCURRENT=4

# === 超时配置（秒）===
# Git 克隆超时
EVAL_GIT_TIMEOUT=300
# LLM HTTP 请求超时
EVAL_LLM_REQUEST_TIMEOUT=300
# LLM 调用超时
EVAL_LLM_TIMEOUT=600

# === LLM 配置 ===
# LLM 最大输出 token
EVAL_LLM_MAX_TOKENS=131072

# === 报告配置 ===
# 报告最大章节长度
EVAL_MAX_SECTION_LENGTH=3000
# 单次 prompt 最大工作流数
EVAL_MAX_WORKFLOWS_SINGLE=10
# 每批工作流数
EVAL_MAX_WORKFLOWS_BATCH=10

# === UI 配置 ===
# 使用 Rich 终端美化
USE_RICH=true

# === LangSmith 追踪 ===
# 设置为 true 启用追踪，需要配置 LANGSMITH_API_KEY
LANGCHAIN_TRACING_V2=false
# LangSmith API Key（从 https://smith.langchain.com 获取）
LANGSMITH_API_KEY=your-langsmith-key
# LangSmith 项目名称
LANGSMITH_PROJECT=eval-agent